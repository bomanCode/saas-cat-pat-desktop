# ============================================================
# Comnyang 2.0 — Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is in .gitignore and must NEVER be committed.
# All variables below are optional unless marked [REQUIRED].
# The app works fully offline without any of the cloud keys.
# ============================================================

# ------------------------------------------------------------
# TAURI / VITE DEV SERVER
# ------------------------------------------------------------

# URL Vite serves during `tauri dev`. Must match vite.config.ts server.port.
# Default: http://localhost:1420 (Tauri v2 convention).
TAURI_DEV_PATH=http://localhost:1420

# Tauri private key for update signing (only needed for release builds).
# Generate once with: `npm run tauri signer generate`
# Leave blank during development.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# ------------------------------------------------------------
# DATABASE (SQLite — local only, no server needed)
# ------------------------------------------------------------

# Path to the SQLite database file.
# Tauri uses its own app-data dir at runtime; this variable is
# only consumed by standalone Rust tests / tooling scripts.
# Windows:  %APPDATA%\com.comnyang.app\comnyang.db
# macOS:    ~/Library/Application Support/com.comnyang.app/comnyang.db
# Linux:    ~/.local/share/com.comnyang.app/comnyang.db
DATABASE_URL=sqlite:./dev.db

# ------------------------------------------------------------
# RUST LOGGING
# ------------------------------------------------------------

# Tracing filter directive — controls what gets printed to stderr.
# Syntax: <crate>=<level>  e.g. comnyang=debug,sqlx=warn
# Levels: error | warn | info | debug | trace
RUST_LOG=comnyang=info,sqlx=warn,tauri=warn

# Rust backtrace on panic (0 = off, 1 = short, full = verbose)
RUST_BACKTRACE=1

# ------------------------------------------------------------
# NODE / VITE
# ------------------------------------------------------------

NODE_ENV=development

# ------------------------------------------------------------
# ANALYTICS — PostHog (optional, offline-safe)
# ------------------------------------------------------------

# Leave blank to disable analytics entirely (recommended for dev).
# Events are queued locally first; if POSTHOG_API_KEY is empty
# the flush loop exits immediately without sending anything.
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------
# AI PROVIDERS (optional — used by Memory Vault + Story Engine)
# ------------------------------------------------------------
# Keys are stored in the OS keychain at runtime via the keyring
# crate; these env vars are a dev convenience so you don't have
# to open the Settings panel on every fresh install.
# None of these are required — Ollama works fully offline.

# OpenAI  https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic / Claude  https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini  https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Ollama (local LLM — no key needed, just a running server)
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------
# DEV / TEST OVERRIDES
# ------------------------------------------------------------

# Rare-event probability check interval in seconds (default 3600 = 1 hour).
# Set to 60 during dev to trigger rare events more frequently.
COMNYANG_RARE_EVENT_INTERVAL_SECS=3600
