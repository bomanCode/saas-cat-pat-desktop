# ============================================================
# Comnyang 2.0 — Dev Container
# Base: node:24-bookworm (Debian 12, amd64)
#
# Includes:
#   - Node.js 24 (from base image)
#   - Rust stable (via rustup)
#   - All Tauri v2 Linux compile-time system deps
#     (webkit2gtk-4.1, libsoup-3.0, gtk3, appindicator, etc.)
#
# Used by podman-compose.yml `dev` service for:
#   cargo check / cargo fmt / cargo test / npm run build
#
# NOT for running `tauri dev` (needs a native OS window + GPU).
# Run tauri dev/build on the HOST (WSL2 terminal), not here.
# ============================================================

FROM node:24-bookworm

# ── System deps for Tauri v2 on Linux ──────────────────────
# Mirrors the packages installed by .github/workflows/ci.yml
# so the container reproduces the exact same build environment.
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Tauri mandatory
    libwebkit2gtk-4.1-dev \
    libappindicator3-dev \
    librsvg2-dev \
    patchelf \
    libsoup-3.0-dev \
    libgtk-3-dev \
    libssl-dev \
    # Build toolchain
    build-essential \
    pkg-config \
    curl \
    wget \
    file \
    git \
    # SQLite (for direct db inspection / sqlite-init service)
    sqlite3 \
    # Cleanup
    && rm -rf /var/lib/apt/lists/*

# ── Rust via rustup ─────────────────────────────────────────
# Install stable toolchain with rustfmt + clippy components.
# CARGO_HOME / RUSTUP_HOME placed in /usr/local so they are
# on PATH for all users (including non-root exec sessions).
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:$PATH

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y \
        --no-modify-path \
        --profile minimal \
        --default-toolchain stable \
        --component rustfmt,clippy \
    && rustc --version \
    && cargo --version

# ── Working directory ───────────────────────────────────────
WORKDIR /workspace

# ── Default command: keep container alive for exec sessions ─
CMD ["sleep", "infinity"]
